---
import TxKitMark from '../icons/TxKitMark.astro'
import './Footer.css'

const year = new Date().getFullYear()

const columns = [
  {
    title: 'Product',
    links: [
      { label: 'GitHub', href: 'https://github.com/txkit/mono' },
      { label: 'npm', href: 'https://www.npmjs.com/org/txkit' },
      { label: 'Issues', href: 'https://github.com/txkit/mono/issues' },
      { label: 'Discussions', href: 'https://github.com/txkit/mono/discussions' },
    ],
  },
  {
    title: 'Protocol',
    links: [
      { label: 'Spec', href: 'https://docs.txkit.dev/protocol/prepared-tx' },
      { label: 'Examples', href: 'https://github.com/txkit/mono/tree/main/packages/tx-protocol/examples' },
      { label: 'Decoder registry', href: 'https://github.com/txkit/mono/tree/main/packages/tx-decoder' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Docs', href: 'https://docs.txkit.dev' },
      { label: 'Blog', href: '/blog/' },
      { label: 'Design partner', href: 'mailto:hello@txkit.dev?subject=txKit%20design%20partner%20interest' },
      { label: 'X / Twitter', href: 'https://x.com/mikediamond_x' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'License (Apache 2.0)', href: 'https://github.com/txkit/mono/blob/main/LICENSE' },
      { label: 'Security', href: 'https://github.com/txkit/mono/security' },
    ],
  },
]
---

<footer class="footer" data-testid="landing-footer">
  <div class="container footer__inner">
    <div class="footer__grid">
      { columns.map((col) => (
        <div class="footer__col">
          <h2 class="footer__col-title mono">{ col.title }</h2>
          <ul class="footer__list">
            { col.links.map((link) => (
              <li>
                <a class="footer__link" href={ link.href }>{ link.label }</a>
              </li>
            )) }
          </ul>
        </div>
      )) }
    </div>

    <div class="footer__bottom">
      <div class="footer__bottom-left">
        <a class="footer__brand" href="/" aria-label="txKit home">
          <TxKitMark size={24} />
          <span class="footer__wordmark">txKit</span>
        </a>
        <p class="footer__tagline">Verify before you sign.</p>
      </div>

      <div class="footer__bottom-right">
        <div class="footer__socials">
          <a
            class="footer__social"
            href="https://github.com/txkit/mono"
            aria-label="txKit on GitHub"
            rel="noreferrer"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
            </svg>
          </a>
          <a
            class="footer__social"
            href="https://x.com/mikediamond_x"
            aria-label="txKit on X"
            rel="noreferrer"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
        </div>
        <p class="footer__copy mono">© { year } txKit</p>
      </div>
    </div>
  </div>
</footer>
