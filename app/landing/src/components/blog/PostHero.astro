---
import PostMeta from './PostMeta.astro'

type Props = {
  title: string,
  description: string,
  pubDate: Date,
  updatedDate?: Date,
  minutesRead?: number,
  tags?: string[],
  heroImage?: string,
  heroAlt?: string,
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  minutesRead,
  tags = [],
  heroImage,
  heroAlt,
} = Astro.props
---

<header class="post-hero">
  <h1 class="post-hero__title">{ title }</h1>
  <p class="post-hero__description">{ description }</p>

  <PostMeta
    pubDate={pubDate}
    updatedDate={updatedDate}
    minutesRead={minutesRead}
    showAuthor={true}
  />

  { tags.length > 0 && (
    <ul class="post-hero__tags mono" aria-label="Tags">
      { tags.map((tag) => (
        <li class="post-hero__tag">{ tag }</li>
      )) }
    </ul>
  ) }

  { heroImage && heroAlt && (
    <figure class="post-hero__figure">
      <img src={heroImage} alt={heroAlt} loading="eager" decoding="async" />
    </figure>
  ) }
</header>

<style>
  .post-hero {
    margin-bottom: 2rem;
  }

  .post-hero__title {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 5vw, 2.75rem);
    line-height: 1.15;
    letter-spacing: -0.025em;
    font-weight: 700;
    color: var(--txkit-color-text);
  }

  .post-hero__description {
    margin: 0 0 1.5rem;
    font-size: 1.125rem;
    line-height: 1.55;
    color: var(--txkit-color-text-secondary);
  }

  .post-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .post-hero__tag {
    padding: 0.2rem 0.55rem;
    background: var(--txkit-color-bg-elevated);
    border: 1px solid var(--txkit-color-border);
    border-radius: var(--txkit-radius-pill);
    font-size: 0.75rem;
    color: var(--txkit-color-text-tertiary);
    letter-spacing: 0.02em;
  }

  .post-hero__figure {
    margin: 2.5rem 0 0;
  }

  .post-hero__figure img {
    width: 100%;
    height: auto;
    border-radius: var(--txkit-radius-md);
    border: 1px solid var(--txkit-color-border);
  }

  @media (max-width: 640px) {
    .post-hero__description {
      font-size: 1rem;
    }
  }
</style>
