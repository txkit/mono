---
type Props = {
  pubDate: Date,
  updatedDate?: Date,
  minutesRead?: number,
  showAuthor?: boolean,
}

const {
  pubDate,
  updatedDate,
  minutesRead,
  showAuthor = false,
} = Astro.props

const formatDate = (date: Date) => date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

const isoString = pubDate.toISOString()
const displayDate = formatDate(pubDate)
const updatedDisplay = updatedDate ? formatDate(updatedDate) : null
const readingLabel = minutesRead ? `${ minutesRead } min read` : null
---

<div class="post-meta mono">
  <time datetime={isoString}>{ displayDate }</time>

  { showAuthor && (
    <>
      <span class="post-meta__sep" aria-hidden="true">·</span>
      <span class="post-meta__author">
        By <a href="/" class="post-meta__author-link">Michael Diamond</a>
      </span>
    </>
  ) }

  { readingLabel && (
    <>
      <span class="post-meta__sep" aria-hidden="true">·</span>
      <span>{ readingLabel }</span>
    </>
  ) }

  { updatedDisplay && (
    <>
      <span class="post-meta__sep" aria-hidden="true">·</span>
      <span class="post-meta__updated">Updated { updatedDisplay }</span>
    </>
  ) }
</div>

<style>
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--txkit-color-text-tertiary);
    letter-spacing: 0;
  }

  .post-meta__sep {
    color: var(--txkit-color-text-tertiary);
    opacity: 0.5;
  }

  .post-meta__author-link {
    color: var(--txkit-color-text-secondary);
    text-decoration: underline;
    text-decoration-color: var(--txkit-color-border);
    text-underline-offset: 0.2em;
    transition: text-decoration-color var(--txkit-duration-fast) var(--txkit-easing);
  }

  .post-meta__author-link:hover {
    text-decoration-color: var(--txkit-color-text);
  }

  .post-meta__updated {
    font-style: italic;
  }

  @media (prefers-reduced-motion: reduce) {
    .post-meta__author-link {
      transition: none;
    }
  }
</style>
