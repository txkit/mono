---
type Props = {
  size?: number,
  className?: string,
}

const { size = 32, className } = Astro.props
---

<svg
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
>
  <rect width="32" height="32" rx="7" fill="#4338CA" />
  <text
    x="16"
    y="22"
    text-anchor="middle"
    font-family="'IBM Plex Mono', monospace"
    font-weight="700"
    font-size="16"
    fill="#FFFFFF"
    letter-spacing="-0.04em"
  >tx</text>
</svg>
