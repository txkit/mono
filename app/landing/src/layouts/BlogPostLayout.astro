---
import BaseLayout from './BaseLayout.astro'
import Header from '../components/Header/Header.astro'
import Footer from '../components/Footer/Footer.astro'
import PostHero from '../components/blog/PostHero.astro'
import '../styles/prose.css'

type Props = {
  title: string,
  description: string,
  pubDate: Date,
  updatedDate?: Date,
  tags?: string[],
  heroImage?: string,
  heroAlt?: string,
  minutesRead?: number,
  slug: string,
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  heroImage,
  heroAlt,
  minutesRead,
  slug,
} = Astro.props

const siteUrl = 'https://txkit.dev'
const canonical = `${ siteUrl }/blog/${ slug }/`
const ogImage = heroImage || '/og.svg'
const ogImageUrl = new URL(ogImage, siteUrl).href
const pageTitle = `${ title } - txKit Blog`

const blogPostingJsonLd = {
  '@type': 'BlogPosting',
  '@id': `${ canonical }#article`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate || pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: 'Michael Diamond',
    url: `${ siteUrl }/`,
  },
  publisher: { '@id': `${ siteUrl }/#organization` },
  image: ogImageUrl,
  keywords: tags.join(', '),
  inLanguage: 'en',
}
---

<BaseLayout
  title={pageTitle}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogType="article"
  extraGraphNodes={[ blogPostingJsonLd ]}
>
  <Fragment slot="head-extra">
    <meta property="article:published_time" content={pubDate.toISOString()} />
    { updatedDate && (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    ) }
    <meta property="article:author" content="Michael Diamond" />
    { tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    )) }
    <link rel="alternate" type="application/rss+xml" title="txKit Blog" href="/blog/rss.xml" />
  </Fragment>

  <Header />

  <main id="main" class="blog-post">
    <article class="blog-post__article">
      <a class="blog-post__back" href="/blog/" rel="prev">
        <span aria-hidden="true">←</span> All posts
      </a>

      <PostHero
        title={title}
        description={description}
        pubDate={pubDate}
        updatedDate={updatedDate}
        minutesRead={minutesRead}
        tags={tags}
        heroImage={heroImage}
        heroAlt={heroAlt}
      />

      <div class="prose blog-post__body">
        <slot />
      </div>

      <footer class="blog-post__footer">
        <p class="blog-post__followup">
          Found this useful? Follow new posts via <a href="/blog/rss.xml">RSS</a>, or on <a href="https://x.com/mikediamond_x" rel="noreferrer">X</a>.
        </p>
      </footer>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .blog-post {
    padding: 4rem 0 6rem;
  }

  .blog-post__article {
    margin: 0 auto;
    padding: 0 1.5rem;
    max-width: 720px;
  }

  .blog-post__back {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 2rem;
    min-height: 44px;
    font-size: 0.875rem;
    color: var(--txkit-color-text-tertiary);
    transition: color var(--txkit-duration-fast) var(--txkit-easing);
  }

  .blog-post__back:hover {
    color: var(--txkit-color-text);
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-post__back {
      transition: none;
    }
  }

  .blog-post__body {
    margin-top: 2.5rem;
  }

  .blog-post__footer {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--txkit-color-border);
  }

  .blog-post__followup {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--txkit-color-text-tertiary);
    text-align: center;
  }

  .blog-post__followup a {
    color: var(--txkit-color-text-secondary);
    text-decoration: underline;
    text-decoration-color: var(--txkit-color-primary-border);
    text-underline-offset: 0.2em;
    transition: text-decoration-color var(--txkit-duration-fast) var(--txkit-easing);
  }

  .blog-post__followup a:hover {
    text-decoration-color: var(--txkit-color-text);
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-post__followup a {
      transition: none;
    }
  }

  @media (max-width: 640px) {
    .blog-post {
      padding: 2rem 0 4rem;
    }

    .blog-post__article {
      padding: 0 1rem;
    }
  }
</style>
