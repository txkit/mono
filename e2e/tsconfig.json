{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [ "node" ]
  },
  "include": [ "**/*.ts", "helpers/**/*.js" ],
  "exclude": [ "node_modules", "test-results", "playwright-report" ]
}
