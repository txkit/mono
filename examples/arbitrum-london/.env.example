# txKit Arbitrum London Buildathon - environment template
# Copy to .env.local and fill in. Server-only secrets (no NEXT_PUBLIC_ prefix)
# never reach the client bundle.

# -- Claude Agent SDK (REQUIRED for /api/agent) --
ANTHROPIC_API_KEY=sk-ant-...

# -- Arbitrum Sepolia (Scenario A) --
ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBISCAN_API_KEY=

# -- Robinhood Chain testnet, chainId 46630 (Scenario C) --
ROBINHOOD_TESTNET_RPC_URL=https://testnet.rpc.chain.robinhood.com

# -- Deployer + agent signer (REQUIRED for forge scripts in contracts/) --
DEPLOYER_PRIVATE_KEY=0x...
AGENT_SIGNER_ADDRESS=0x...

# -- x402 facilitator (REQUIRED for /api/x402/* - lands Phase 2) --
X402_FACILITATOR_PRIVATE_KEY=0x...
