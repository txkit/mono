{
  "name": "@txkit/mcp-server",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Hardened MCP server for AI agents to prepare, decode, and simulate Web3 transactions. Zod-sanitized tool inputs, narrow intent-based surface, no shell access, stdio + HTTP transports. Built post-CVE-2026-30615.",
  "license": "MIT",
  "author": "Michael Diamond",
  "homepage": "https://docs.txkit.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/txkit/mono.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/txkit/mono/issues"
  },
  "keywords": [
    "txkit",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "claude",
    "anthropic",
    "web3",
    "ethereum",
    "agentcore",
    "bedrock",
    "openai",
    "gemini",
    "hardened",
    "sandbox",
    "zod"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.18"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "txkit-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@txkit/tx-protocol": "workspace:^",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.1"
  },
  "sideEffects": false
}
