{
  "name": "@txkit/react",
  "version": "0.1.0-alpha.3",
  "description": "React components for Web3 - connect, transact, display",
  "license": "Apache-2.0",
  "author": "Michael Diamond",
  "homepage": "https://txkit.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/txkit/mono.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/txkit/mono/issues"
  },
  "keywords": [
    "txkit",
    "react",
    "web3",
    "ethereum",
    "components",
    "wallet",
    "connect-wallet",
    "token-balance",
    "transaction-button",
    "flow",
    "multi-step",
    "defi",
    "wagmi",
    "viem",
    "ui-kit",
    "anti-phishing",
    "dapp",
    "hooks",
    "headless",
    "erc20",
    "arbitrum",
    "optimism",
    "base",
    "sepolia",
    "accessibility"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsup && postcss src/styles.css -o dist/styles.css",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@paulmillr/qr": "^0.3.0",
    "@txkit/core": "workspace:^"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "react": ">=18",
    "react-dom": ">=18",
    "viem": ">=2",
    "wagmi": ">=3"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.100.14",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "viem": "^2.51.0",
    "wagmi": "^3.6.15"
  },
  "sideEffects": [
    "*.css"
  ]
}
